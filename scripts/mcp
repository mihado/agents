#!/usr/bin/env node

import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import { spawnSync } from "node:child_process";
import { fileURLToPath } from "node:url";

const root = path.dirname(path.dirname(fileURLToPath(import.meta.url)));
const manifestPath = path.join(root, "mcp.json");
const claudeConfig =
  process.env.CLAUDE_CONFIG || path.join(os.homedir(), ".claude.json");
const command = process.argv[2];

if (!["--install", "--check"].includes(command) || process.argv.length !== 3) {
  fail("Usage: scripts/mcp --install | --check");
}

const manifest = readJson(manifestPath);
validateManifest(manifest);

const tools = {
  codex: resolveExecutable(
    process.env.CODEX_CLI_PATH,
    "codex",
    "/Applications/Codex.app/Contents/Resources/codex",
  ),
  claude: resolveExecutable(process.env.CLAUDE_CLI_PATH, "claude"),
  opencode: resolveExecutable(process.env.OPENCODE_CLI_PATH, "opencode"),
};

if (!tools.codex && !tools.claude && !tools.opencode) {
  fail("no supported tool installed (codex, claude, or opencode)");
}

let failures = 0;

for (const [name, server] of Object.entries(manifest.servers)) {
  if (tools.codex) {
    handleTool("Codex", name, server, codexStatus, installCodex);
  }
  if (tools.claude) {
    handleTool("Claude", name, server, claudeStatus, installClaude);
  }
  if (tools.opencode) {
    handleOpenCodeTool(name, server);
  }
}

process.exit(failures);

function handleTool(label, name, server, statusFn, installFn) {
  const status = statusFn(name, server);

  if (command === "--check") {
    if (status === "exact") {
      console.log(`PASS  ${label} ${name} configured`);
    } else {
      console.error(
        `FAIL  ${label} ${name} ${status === "missing" ? "is not configured" : "configuration conflicts with mcp.json"}`,
      );
      failures += 1;
    }
    return;
  }

  if (status === "exact") {
    console.log(`ok: ${label} ${name}`);
    return;
  }

  if (status === "conflict") {
    console.error(`error: ${label} ${name} conflicts with mcp.json`);
    failures += 1;
    return;
  }

  installFn(name, server);
  console.log(`installed: ${label} ${name}`);
}

function codexStatus(name, server) {
  const result = spawnSync(tools.codex, ["mcp", "get", name], {
    encoding: "utf8",
  });
  if (result.status !== 0) return "missing";

  const details = parseKeyValueOutput(result.stdout);
  const args = server.args.join(" ");
  return details.transport === server.type &&
    details.command === server.command &&
    details.args === (args || "-")
    ? "exact"
    : "conflict";
}

function claudeStatus(name, server) {
  if (!fs.existsSync(claudeConfig)) return "missing";

  const config = readJson(claudeConfig);
  const current = config.mcpServers?.[name];
  if (!current) return "missing";

  return current.type === server.type &&
    current.command === server.command &&
    JSON.stringify(current.args || []) === JSON.stringify(server.args)
    ? "exact"
    : "conflict";
}

function installCodex(name, server) {
  run(tools.codex, [
    "mcp",
    "add",
    name,
    "--",
    server.command,
    ...server.args,
  ]);
}

function installClaude(name, server) {
  run(tools.claude, [
    "mcp",
    "add",
    "--scope",
    "user",
    name,
    "--",
    server.command,
    ...server.args,
  ]);
}

function validateManifest(current) {
  if (current.version !== 1) fail("mcp.json version must be 1");
  if (!isObject(current.servers) || Object.keys(current.servers).length === 0) {
    fail("mcp.json must contain at least one server");
  }

  for (const [name, server] of Object.entries(current.servers)) {
    if (
      !name ||
      server.type !== "stdio" ||
      typeof server.command !== "string" ||
      !server.command ||
      !Array.isArray(server.args) ||
      !server.args.every((arg) => typeof arg === "string") ||
      !Array.isArray(server.env || []) ||
      !(server.env || []).every((key) => typeof key === "string")
    ) {
      fail(`invalid MCP server definition: ${name}`);
    }
  }
}

function parseKeyValueOutput(output) {
  const values = {};
  for (const line of output.split("\n")) {
    const match = line.match(/^\s+([a-z]+):\s*(.*)$/);
    if (match) values[match[1]] = match[2];
  }
  return values;
}

function resolveExecutable(override, name, ...fallbacks) {
  for (const candidate of [override, findOnPath(name), ...fallbacks]) {
    if (candidate && isExecutable(candidate)) return candidate;
  }
  return null;
}

function findOnPath(name) {
  for (const directory of (process.env.PATH || "").split(path.delimiter)) {
    if (!directory) continue;
    const candidate = path.join(directory, name);
    if (isExecutable(candidate)) return candidate;
  }
  return null;
}

function isExecutable(file) {
  try {
    fs.accessSync(file, fs.constants.X_OK);
    return true;
  } catch {
    return false;
  }
}

function readJson(file) {
  try {
    return JSON.parse(fs.readFileSync(file, "utf8"));
  } catch (error) {
    fail(`cannot read ${file}: ${error.message}`);
  }
}

function isObject(value) {
  return value !== null && typeof value === "object" && !Array.isArray(value);
}

function run(executable, args) {
  const result = spawnSync(executable, args, { encoding: "utf8" });
  if (result.status !== 0) {
    fail(`${executable} ${args.join(" ")} failed:\n${result.stderr.trim()}`);
  }
}

// OpenCode uses a JSONC config file at ~/.config/opencode/opencode.jsonc
function getOpenCodeConfigPath() {
  const configHome = process.env.XDG_CONFIG_HOME || path.join(os.homedir(), ".config");
  return path.join(configHome, "opencode", "opencode.jsonc");
}

// Strips JSONC comments from a string
function parseJSONC(content) {
  // Remove single-line comments
  const withoutSingleLine = content.replace(/\/\/.*$/gm, "");
  // Remove multi-line comments
  const withoutMultiLine = withoutSingleLine.replace(/\/\*[\s\S]*?\*\//g, "");
  return JSON.parse(withoutMultiLine);
}

function openCodeStatus(name, server) {
  const configPath = getOpenCodeConfigPath();
  if (!fs.existsSync(configPath)) return "missing";

  try {
    const content = fs.readFileSync(configPath, "utf8");
    const config = parseJSONC(content);
    const current = config.mcp?.[name];
    if (!current) return "missing";

    // For OpenCode, we only support 'remote' type with url
    // Map from mcp.json stdio definition to OpenCode remote if possible
    const opencodeServer = toOpenCodeRemote(server);
    if (!opencodeServer) return "conflict";

    return current.type === opencodeServer.type &&
      current.url === opencodeServer.url &&
      JSON.stringify(current.headers || {}) === JSON.stringify(opencodeServer.headers || {})
      ? "exact"
      : "conflict";
  } catch {
    return "missing";
  }
}

// Converts a mcp.json server definition to OpenCode remote format if possible
function toOpenCodeRemote(server) {
  // OpenCode supports 'remote' type with a URL
  // For npx-based servers like context7, we can use the remote endpoint
  if (server.command === "npx" && server.args.includes("@upstash/context7-mcp")) {
    return {
      type: "remote",
      url: "https://mcp.context7.com/mcp",
      headers: server.env?.includes("CONTEXT7_API_KEY")
        ? { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" }
        : {},
    };
  }
  // Add other known remote mappings here
  return null;
}

function installOpenCode(name, server) {
  const opencodeServer = toOpenCodeRemote(server);
  if (!opencodeServer) {
    console.error(`error: ${name} cannot be configured for OpenCode (no remote mapping)`);
    failures += 1;
    return;
  }

  const configPath = getOpenCodeConfigPath();
  let config = { mcp: {} };

  if (fs.existsSync(configPath)) {
    try {
      const content = fs.readFileSync(configPath, "utf8");
      config = parseJSONC(content);
      if (!config.mcp) config.mcp = {};
    } catch {
      // If we can't parse it, start fresh
      config = { mcp: {} };
    }
  } else {
    // Ensure directory exists
    fs.mkdirSync(path.dirname(configPath), { recursive: true });
  }

  config.mcp[name] = opencodeServer;

  // Write back as JSONC (with comments preserved if possible, otherwise just JSON)
  fs.writeFileSync(configPath, JSON.stringify(config, null, 2) + "\n");
}

function handleOpenCodeTool(name, server) {
  const status = openCodeStatus(name, server);

  if (command === "--check") {
    if (status === "exact") {
      console.log(`PASS  OpenCode ${name} configured`);
    } else {
      console.error(
        `FAIL  OpenCode ${name} ${status === "missing" ? "is not configured" : "configuration conflicts or unsupported"}`,
      );
      failures += 1;
    }
    return;
  }

  if (status === "exact") {
    console.log(`ok: OpenCode ${name}`);
    return;
  }

  if (status === "conflict") {
    console.error(`error: OpenCode ${name} conflicts with mcp.json`);
    failures += 1;
    return;
  }

  installOpenCode(name, server);
  console.log(`installed: OpenCode ${name}`);
}

function fail(message) {
  console.error(`error: ${message}`);
  process.exit(1);
}
